PORT=5000
FRONTEND_URL=http://localhost:5174
# Comma-separated extra CORS origins (optional, e.g. custom domain)
# ALLOWED_ORIGINS=https://portal.chabadbedford.org

CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
# Clerk JWT clock tolerance in ms (default 5 minutes). Also set Session lifetime in Clerk Dashboard.
SESSION_CLOCK_SKEW_MS=300000
MAKE_WEBHOOK_URL=https://hook.us2.make.com/your_member_lookup_webhook
MAKE_PROFILE_UPDATE_WEBHOOK_URL=https://hook.us2.make.com/your_profile_update_webhook
MAKE_PORTAL_DATA_WEBHOOK_URL=https://hook.us2.make.com/your_portal_data_webhook
# Dedicated household data webhook (contacts + relationships) — separate from portal data
MAKE_HOUSEHOLD_DATA_WEBHOOK_URL=https://hook.us2.make.com/your_household_data_webhook
MAKE_PAYMENTS_WEBHOOK_URL=https://hook.us2.make.com/your_payments_fetch_webhook
MAKE_QUICK_PAYMENT_WEBHOOK_URL=https://hook.us2.make.com/your_pledge_only_webhook
MAKE_STRIPE_PAYMENT_WEBHOOK_URL=https://hook.us2.make.com/your_stripe_payment_sync_webhook
MAKE_HOUSEHOLD_SEARCH_CONTACTS_WEBHOOK_URL=https://hook.us2.make.com/your_household_search_contacts_webhook
MAKE_ADD_FAMILY_MEMBER_WEBHOOK_URL=https://hook.us2.make.com/your_add_family_member_webhook
# Optional dedicated webhook for Salesforce role updates (set_household_role route)
MAKE_HOUSEHOLD_ROLE_WEBHOOK_URL=https://hook.us2.make.com/your_set_household_role_webhook
# Returns live Contribution Type / Sub-Type picklist values from Salesforce (OneCRM__Type__c / OneCRM__Sub_Type__c).
# Expected JSON response: { "types": [ { "id", "label", "subTypes": [ { "id", "label" } ] } ] }
# Falls back to a static Donation-only list if unset or unreachable.
MAKE_CONTRIBUTION_OPTIONS_WEBHOOK_URL=https://hook.us2.make.com/your_contribution_options_webhook

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# ChabadOne org defaults for portal-created recurring billing (optional)
RECURRING_INVOICE_NAME=Invoice - Hebrew School - PDF
RECURRING_LETTERHEAD_NAME=Letterhead - 220 BW

# Legacy (optional)
JWT_SECRET=change_me
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
